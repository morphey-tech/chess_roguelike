      m_Calls: []
  m_text: "\u041C\u043E\u0449\u043D\u044B\u0439 \u0431\u043E\u0435\u0446, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430\u0431\u0438\u0440\u0430\u0435\u0442 \u0441\u0438\u043B\u0443 \u0441
    \u0440\u0430\u0437\u0431\u0435\u0433\u0430. \u0427\u0435\u043C \u0434\u043B\u0438\u043D\u043D\u0435\u0435
    \u043F\u0443\u0442\u044C \u0434\u043E \u0446\u0435\u043B\u0438, \u0442\u0435\u043C
    \u0441\u043E\u043A\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u0435\u0435
    \u0443\u0434\u0430\u0440.\n\u0422\u0440\u0435\u0431\u0443\u0435\u0442 \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u0445
    \u043B\u0438\u043D\u0438\u0439 \u0434\u043B\u044F \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438."
